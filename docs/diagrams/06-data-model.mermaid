---
title: Clawless データモデル（Entity Relationship）
---
erDiagram
    SETTINGS_JSON {
        object permissions "deny / ask / allow arrays"
        array hooks "Hook event bindings"
        object sandbox "Filesystem + network rules"
        string env_CLAWLESS_PROFILE "minimal / standard / strict"
    }

    HOOK_SCRIPT {
        string filename "e.g. clawless-permission.sh"
        string event_type "PreToolUse / PostToolUse / ..."
        string language "bash+jq or node"
        string security_domain "One per hook"
        string sha256_hash "Integrity verification"
    }

    INJECTION_PATTERNS {
        string format "JSON"
        int category_count "9 categories"
        int pattern_count "50+ patterns"
        string origin "claude-guardrails / tobari / custom"
        date last_updated "Freshness tracking"
    }

    EVIDENCE_LEDGER {
        string entry_id "UUID v4"
        datetime timestamp "ISO 8601"
        string event_type "tool_call / block / warning"
        string tool_name "Bash / Edit / Write / ..."
        string decision "allow / block / modify"
        string reason "Block reason if applicable"
        string prev_hash "SHA-256 of previous entry"
        string current_hash "SHA-256 of this entry"
    }

    SESSION_STATE {
        string session_id "Unique per session"
        string profile "minimal / standard / strict"
        string claude_code_version "e.g. v2.1.80"
        string os_type "windows / wsl2 / linux / macos"
        boolean sandbox_available "OS sandbox status"
        int retry_counter "Circuit breaker state"
        datetime started_at "Session start time"
        string claude_md_hash "CLAUDE.md SHA-256"
    }

    COMPACT_BACKUP {
        string backup_id "Pre-compact snapshot ID"
        string session_id "FK to SESSION_STATE"
        object gate_state "Gate check results"
        object session_snapshot "Full session state"
        string claude_md_hash "For post-compact verify"
        datetime created_at "Backup timestamp"
    }

    SENDER_ALLOWLIST {
        string platform "telegram / discord"
        string sender_id "Platform-specific user ID"
        string display_name "Human-readable name"
        string dm_scope "per-channel-peer / shared"
        boolean active "Enabled status"
    }

    GATEWAY_CONFIG {
        string bind_address "127.0.0.1:PORT"
        string tunnel_type "cloudflare"
        array platforms "Connected platforms"
        object rate_limits "Per-sender rate config"
    }

    SETTINGS_JSON ||--o{ HOOK_SCRIPT : "registers"
    HOOK_SCRIPT ||--|| INJECTION_PATTERNS : "references"
    HOOK_SCRIPT ||--o{ EVIDENCE_LEDGER : "writes"
    SESSION_STATE ||--o{ EVIDENCE_LEDGER : "contains"
    SESSION_STATE ||--o{ COMPACT_BACKUP : "snapshots"
    GATEWAY_CONFIG ||--o{ SENDER_ALLOWLIST : "authorizes"
    SESSION_STATE }o--|| SETTINGS_JSON : "configured by"
    GATEWAY_CONFIG }o--|| SETTINGS_JSON : "configured by"
