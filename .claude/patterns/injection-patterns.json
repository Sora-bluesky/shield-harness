      "action": "deny"
    },
    "encoding_attack": {
      "severity": "high",
      "description": "Encoding/obfuscation attacks — base64, Unicode escape, homoglyph (TH-02-4)",
      "patterns": [
        "eval\\s*\\(\\s*atob\\s*\\(",
        "Buffer\\.from\\s*\\([^)]+,\\s*['\"]base64['\"]\\)",
