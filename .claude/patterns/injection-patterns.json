        "\\u200[b-f]",
        "\\u00ad",
        "\\ufeff"
      ],
      "action": "deny"
    },
    "context_manipulation": {
      "severity": "high",
      "description": "Context manipulation — fake system messages, delimiter injection (TH-02-5)",
      "patterns": [
        "<system[_-]?(message|prompt|reminder)>",
