        "act\\s+as\\s+(if\\s+you\\s+are\\s+)?(a|an)?\\s*(unrestricted|unfiltered|jailbroken|DAN)",
        "pretend\\s+(you\\s+are|to\\s+be)\\s+(a|an)?\\s*(unrestricted|evil|malicious)",
